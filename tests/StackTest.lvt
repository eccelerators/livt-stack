namespace Livt.Collections.Tests

using Livt.Collections

@Test
component StackTest
{
	stack : Stack

	new()
	{
		stack = new Stack()
	}

	@Test
	fn TestPush()
	{
		stack.Clear()

		stack.Push(0b0000_0001)

		assert stack.Peek() == 0b0000_0001
		assert stack.GetPosition() == 1
		assert stack.IsEmpty() == false
	}

	@Test
	fn TestPop()
	{
		stack.Clear()
		stack.Push(0b0000_0001)
		stack.Push(0b0000_0000)
		stack.Push(0b0000_0011)

		assert stack.Pop() == 0b0000_0011
		assert stack.Pop() == 0b0000_0000
		assert stack.Pop() == 0b0000_0001
		assert stack.Pop() == 0b0000_0000
		assert stack.GetPosition() == 0
	}

	@Test
	fn TestPeek()
	{
		stack.Clear()
		stack.Push(0b0000_0001)
		stack.Push(0b0000_0010)

		assert stack.Peek() == 0b0000_0010
		assert stack.Peek() == 0b0000_0010
		assert stack.GetPosition() == 2
	}

	@Test
	fn TestPeekOnEmptyStack()
	{
		stack.Clear()

		assert stack.Peek() == 0b0000_0000
	}

	@Test
	fn TestLIFOOrder()
	{
		stack.Clear()
		stack.Push(0b0000_0001)
		stack.Push(0b0000_0010)
		stack.Push(0b0000_0011)

		assert stack.Pop() == 0b0000_0011
		assert stack.Pop() == 0b0000_0010
		assert stack.Pop() == 0b0000_0001
	}

	@Test
	fn TestIsFull()
	{
		stack.Clear()
		for (var i=0; i < 32; i++) {
			stack.Push(0b0000_0001)
		}

		assert stack.IsFull() == true
		assert stack.GetPosition() == 32
	}

	@Test
	fn TestIsEmpty()
	{
		stack.Clear()

		assert stack.IsEmpty() == true
	}

	@Test
	fn TestGetPosition()
	{
		stack.Clear()

		var startPosition = stack.GetPosition()

		stack.Push(0b0000_0001)
		stack.Push(0bZZZZ_ZZZZ)
		stack.Push(0bUUUU_UUUU)
		stack.Push(0bXXXX_XXXX)

		assert startPosition == 0
		assert stack.GetPosition() == 4
	}

	@Test
	fn TestPushIgnoredWhenFull()
	{
		stack.Clear()
		for (var i=0; i < 32; i++) {
			stack.Push(0b0000_0001)
		}

		stack.Push(0b0000_0010)

		for (var i=0; i < 32; i++) {
			assert stack.Pop() == 0b0000_0001
		}

		assert stack.IsEmpty() == true
		assert stack.Pop() == 0b0000_0000
	}

	@Test
	fn TestClear()
	{
		stack.Clear()
		stack.Push(0b0000_0001)
		stack.Push(0b0000_0010)

		stack.Clear()

		assert stack.IsEmpty() == true
		assert stack.GetPosition() == 0
		assert stack.Pop() == 0b0000_0000
	}
}
